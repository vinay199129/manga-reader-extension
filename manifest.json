{
  "manifest_version": 3,
  "name": "Manga Reader",
  "version": "0.1.0",
  "description": "Cinematic, narrated manga reading experience",

  "permissions": ["activeTab", "scripting", "storage", "tts", "offscreen", "tabs"],
  "host_permissions": ["<all_urls>"],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "src/background.js"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [{
    "resources": [
      "src/engine/*.js",
      "src/content.js",
      "lib/*",
      "lib/tesseract/*",
      "lib/transformers/*",
      "offscreen/*"
    ],
    "matches": ["<all_urls>"]
  }],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https:"
  }
}
